# Copia este archivo como .env y rellena los valores reales

# Cadena de conexión a PostgreSQL de Supabase
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# URL pública de tu proyecto Supabase
SUPABASE_URL="https://<project-ref>.supabase.co"

# Service Role Key (Settings → API → service_role). NUNCA la expongas en el cliente.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Puerto del servidor NestJS (opcional, default 3000)
# PORT=3000
