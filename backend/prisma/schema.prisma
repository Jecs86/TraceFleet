// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. ENTIDAD SAAS (AISLAMIENTO DE INQUILINOS)
// ==========================================
model Empresa {
  id                  String                @id @default(uuid())
  nombre              String                // Ej: "Logística del Sur S.A." o "TransBuses S.A."
  tipoIndustria       String?               // Ej: "Combustible", "Pasajeros", "Carga"
  usuarios            Usuario[]
  vehiculos           Vehiculo[]
  viajes              Viaje[]
  createdAt           DateTime              @default(now())
}

enum RolUsuario {
  ADMIN
  GERENTE
  CHOFER
}

enum TipoCombustible {
  ECO
  SUPER
  DIESEL
}

// ==========================================
// 2. USUARIOS Y CONTROL DE ACCESO
// ==========================================
model Usuario {
  id                  String                @id @default(uuid())
  authId              String                @unique // ID devuelto por Supabase Auth
  empresaId           String?               // NULL solo para ADMIN (usuario de la plataforma SaaS)
  empresa             Empresa?              @relation(fields: [empresaId], references: [id])
  nombre              String
  correo              String                @unique
  rol                 RolUsuario            @default(CHOFER)
  estadoActivo        Boolean               @default(true)
  
  viajes              Viaje[]
  registrosCombustible RegistroCombustible[]
  gastos               GastoExtra[]
}

// ==========================================
// 3. FLOTA (ABSTRACCIÓN DE VEHÍCULOS)
// ==========================================
model Vehiculo {
  id                  String                @id @default(uuid())
  empresaId           String
  empresa             Empresa               @relation(fields: [empresaId], references: [id])
  placa               String                @unique // Ej: GBN8210, GTI1548
  tipo                String                // Ej: "Tanquero", "Bus de pasajeros", "Mula"
  marca               String?
  estadoOperativo     Boolean               @default(true)
  imagenUrl           String?               // URL pública de la foto del vehículo en Supabase Storage
  
  documentos          DocumentoVehiculo[]
  viajes              Viaje[]
  registrosCombustible RegistroCombustible[]
  gastos               GastoExtra[]
  mantenimientos      Mantenimiento[]
}

// ==========================================
// 4. CONTROL DOCUMENTAL (ALERTAS DE CADUCIDAD)
// ==========================================
model DocumentoVehiculo {
  id                  String                @id @default(uuid())
  vehiculoId          String
  vehiculo            Vehiculo              @relation(fields: [vehiculoId], references: [id])
  tipoDocumento       String                // Ej: "Póliza de Seguro", "Matrícula", "Permiso Bomberos"
  fechaEmision        DateTime?
  fechaExpiracion     DateTime?
  costo               Float?
  archivoUrl          String?               // URL de Supabase Storage
  createdAt           DateTime              @default(now())
}

// ==========================================
// 5. OPERACIÓN / LOGÍSTICA (NÚCLEO DEL SAAS)
// ==========================================
model Viaje {
  id                  String                @id @default(uuid())
  empresaId           String
  empresa             Empresa               @relation(fields: [empresaId], references: [id])
  vehiculoId          String
  vehiculo            Vehiculo              @relation(fields: [vehiculoId], references: [id])
  choferId            String
  chofer              Usuario               @relation(fields: [choferId], references: [id])
  
  origen              String
  destino             String
  fechaSalida         DateTime              @default(now())
  fechaLlegada        DateTime?
  estado              String                @default("EN_RUTA") // EN_RUTA, FINALIZADO, RETRASADO
  
  // Abstracción de Mercancía o Carga
  tipoCarga           String?               // Ej: "Diesel (Mercancía)", "Pasajeros", "Cacao"
  cantidadCarga       Float?                // Ej: 10000, 42, 25
  unidadMedida        String?               // Ej: "Galones", "Personas", "Toneladas"
  
  ingresoServicio     Float                 @default(0)

  // Relaciones inversas
  registrosCombustible RegistroCombustible[]
  gastos               GastoExtra[]

  liquidacion          LiquidacionViaje?
}

// ==========================================
// 6. CONSUMO DE COMBUSTIBLE DEL MOTOR
// ==========================================
model RegistroCombustible {
  id                  String                @id @default(uuid())
  vehiculoId          String
  vehiculo            Vehiculo              @relation(fields: [vehiculoId], references: [id])
  choferId            String
  chofer              Usuario               @relation(fields: [choferId], references: [id])
  viajeId             String?               // RELACIÓN AGREGADA: Opcional para máxima flexibilidad SaaS
  viaje               Viaje?                @relation(fields: [viajeId], references: [id])
  
  fecha               DateTime              @default(now())
  estacion            String?               // Ej: "BASTION", "AYACUCHO" (mapeado de tus Excels)
  tipoCombustible     TipoCombustible       // ECO, SUPER, DIESEL
  galones             Float
  costoTotal          Float
  distancia           Float                 // Kilometraje actual del odómetro al momento del tanqueo
  rendimientoCalculado Float?               // km/galón (Calculado por NestJS antes de guardar)
  precioPorGalon      Float?               // Precio real pagado por galón (costoTotal / galones), para auditoría
  estado              String                @default("OK") // OK, ANOMALIA
  facturaUrl          String?               // URL de la foto en Supabase Storage
}

// ==========================================
// 7. GASTOS EN RUTA (PEAJES, VIÁTICOS, ETC.)
// ==========================================
model GastoExtra {
  id                  String                @id @default(uuid())
  vehiculoId          String
  vehiculo            Vehiculo              @relation(fields: [vehiculoId], references: [id])
  choferId            String
  chofer              Usuario               @relation(fields: [choferId], references: [id])
  viajeId             String?               // Vinculado al viaje donde ocurrió el gasto
  viaje               Viaje?                @relation(fields: [viajeId], references: [id])
  
  fecha               DateTime              @default(now())
  categoria           String                // Ej: "Peaje", "Alimentación" (como las fotos enviadas)
  monto               Float
  descripcion         String?
  comprobanteUrl      String?               // URL de la foto en Supabase Storage
}

// ==========================================
// 8. MANTENIMIENTO E HISTORIAL DE TALLER
// ==========================================
model Mantenimiento {
  id                  String                @id @default(uuid())
  vehiculoId          String
  vehiculo            Vehiculo              @relation(fields: [vehiculoId], references: [id])
  
  fecha               DateTime              @default(now())
  tipo                String                // Ej: "Preventivo", "Correctivo"
  descripcion         String                // Ej: "Cambio de aceite y filtros de aire"
  taller              String?
  costo               Float
  kilometraje         Float                 // Odómetro del carro al entrar al taller (Crucial para analíticas)
  facturaUrl          String?               // URL de la factura del taller
}

// ==========================================
// 9. PRECIOS DE COMBUSTIBLE (REGULADOS EN ECUADOR)
// ==========================================
// El ADMIN o GERENTE actualiza estos valores cuando el gobierno cambia el precio oficial.
// El sistema usa el precio vigente al momento de registrar cada tanqueo para auditar discrepancias.
model PrecioCombustible {
  id              String           @id @default(uuid())
  tipo            TipoCombustible  @unique // Un registro por tipo; se sobreescribe al actualizar
  precioPorGalon  Float            // USD — precio oficial vigente (Ej: ECO=2.40, SUPER=2.75, DIESEL=1.90)
  actualizadoEn   DateTime         @default(now()) @updatedAt
}

// ==========================================
// 10. AUDITORÍA FINANCIERA Y CONTROL DE PÉRDIDAS
// ==========================================
model LiquidacionViaje {
  id                       String   @id @default(uuid())
  viajeId                  String   @unique // Garantiza la relación 1:1 con el viaje
  viaje                    Viaje    @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  
  // Totales calculados en ruta
  totalCombustibleReal     Float    // Suma de los costos de RegistroCombustible de este viaje
  totalGastosExtra         Float    // Suma de peajes, viáticos, etc.
  
  // Métricas de Auditoría e Inteligencia del SaaS (Diferencias y Fraudes)
  discrepanciaPrecioCombustible Float @default(0) // Alerta si pagó el galón más caro que el promedio/oficial
  discrepanciaGalones          Float @default(0) // Alerta si el rendimiento real fue menor al esperado del vehículo
  
  // Utilidad e Impacto del Mantenimiento
  ahorroMantenimientoEstimado  Float @default(0) // Cuánto dinero ahorró la empresa por tener el motor afinado (Kpi de valor)
  utilidadNetaViaje            Float // ingresoFlete - (totalCombustibleReal + totalGastosExtra)
  
  createdAt                DateTime @default(now())
}